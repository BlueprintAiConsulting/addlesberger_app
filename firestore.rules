rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Block all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Company document — any authenticated user can read/update, nobody can delete
    match /companies/{companyId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow create, delete: if false;

      // Members — authenticated users can read all, write their own
      match /members/{memberId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && request.auth.uid == memberId;
        allow delete: if false;
      }

      // Board items — any authenticated user in the company
      match /boardItems/{itemId} {
        allow read, create, update, delete: if request.auth != null;
      }

      // Jobs — any authenticated user in the company
      match /jobs/{jobId} {
        allow read, create, update, delete: if request.auth != null;
      }

      // Estimates — any authenticated user in the company
      match /estimates/{estimateId} {
        allow read, create, update, delete: if request.auth != null;
      }

      // Estimate templates — any authenticated user in the company
      match /estimateTemplates/{templateId} {
        allow read, create, update, delete: if request.auth != null;
      }

      // Photos — any authenticated user in the company
      match /photos/{photoId} {
        allow read, create, update, delete: if request.auth != null;
      }
    }
  }
}
